{% extends "base.html" %}
{% block content %}

<div class="row justify-content-center">
    <div class="col-md-5">
        <div class="card shadow-sm">
            <div class="card-body">

                <h4 class="text-center mb-4">Set New Password</h4>

                <form id="resetForm">
                    <div class="mb-3">
                        <label>Reset Token</label>
                        <input type="text" class="form-control" name="token" required>
                    </div>

                    <div class="mb-3">
                        <label>New Password</label>
                        <input type="password" class="form-control" name="new_password" required>
                    </div>

                    <!-- <button class="btn btn-primary w-100">Reset Password</button> -->
                     <button class="btn btn-primary w-100 flex items-center justify-center">
                        <span id="resetSpinner" class="spinner-border spinner-border-sm mr-2 hidden"></span>
                        <span id="resetBtnText">Reset Password</span>
                    </button>

                </form>
                
                <!-- Message placeholders -->
                <div id="resetErrorBox" class="mt-3"></div>
                <div id="resetSuccessBox" class="mt-3"></div>
            </div>
        </div>
    </div>
</div>

<script>
const resetForm = document.getElementById("resetForm");
const resetBtn = resetForm.querySelector("button");
const resetBtnText = document.getElementById("resetBtnText");
const resetSpinner = document.getElementById("resetSpinner");

resetForm.addEventListener("submit", async function(e) {
  e.preventDefault();

    const formData = new FormData(this);

    // Loading state
    resetSpinner.classList.remove("hidden");
    resetBtnText.textContent = "Resetting...";
    resetBtn.disabled = true;

    const res = await fetch("/auth/reset-password", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
        token: formData.get("token"),
        new_password: formData.get("new_password")
        })
    });
    const result = await res.json();

    // Clear old messages
    document.getElementById("resetErrorBox").innerHTML = "";
    document.getElementById("resetSuccessBox").innerHTML = "";

    if (res.ok) {
        document.getElementById("resetSuccessBox").innerHTML =
        `<div class="alert alert-success">${result.message || "Password reset successful."}</div>`;
        setTimeout(() => window.location.href = "/auth/login-page", 1500);
    } else {
        document.getElementById("resetErrorBox").innerHTML =
        `<div class="alert alert-danger">${result.error || "Invalid or expired token."}</div>`;
    }

    // Reset state
    resetSpinner.classList.add("hidden");
    resetBtnText.textContent = "Reset Password";
    resetBtn.disabled = false;

});
</script>

{% endblock %}
